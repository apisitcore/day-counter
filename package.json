{
  "name": "day-counter",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun dist/index.js",
    "build": "bun build src/index.ts --outdir dist --target bun --minify --external @napi-rs/canvas",
    "build:docker": "docker buildx build --platform linux/amd64,linux/arm64 -t day-counter:latest --push ."
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@napi-rs/canvas": "^0.1.95",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
